<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Midnight Moto</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar">
        <div class="logo">Midnight Moto</div>
        <ul class="nav-links">
            <li><a href="#shop">Shop</a></li>
            <li><a href="#build">Build</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <h1>Upgrade Your Ride</h1>
        <p>Custom e-bike parts and performance upgrades</p>
        <a href="#shop" class="btn">Shop Now</a>
    </section>

    <!-- Shop Section -->
    <section id="shop" class="section">
        <h2>Our Parts</h2>
        <div class="products">
            <div class="product-card">
                <img src="images/motor.jpg" alt="Motor">
                <h3>High-Performance Motor</h3>
                <p>$299</p>
                <button>Add to Cart</button>
            </div>
            <div class="product-card">
                <img src="images/battery.jpg" alt="Battery">
                <h3>Long-Life Battery</h3>
                <p>$199</p>
                <button>Add to Cart</button>
            </div>
            <div class="product-card">
                <img src="images/handlebars.jpg" alt="Handlebars">
                <h3>Custom Handlebars</h3>
                <p>$89</p>
                <button>Add to Cart</button>
            </div>
        </div>
    </section>

    <!-- Build Section -->
    <section id="build" class="section">
        <h2>Build Your Bike</h2>
        <p>Choose parts and see your bike come to life!</p>
        <button class="btn">Start Custom Build</button>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section">
        <h2>Contact Us</h2>
        <form>
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea placeholder="Your Message" required></textarea>
            <button type="submit">Send Message</button>
        </form>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 Midnight Moto. All Rights Reserved.</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
